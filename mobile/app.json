{
  "expo": {
    "name": "AREN Assistant",
    "slug": "aren-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "aren",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.aren",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AREN needs access to your microphone to listen to your voice commands.",
        "NSSpeechRecognitionUsageDescription": "AREN needs access to speech recognition to understand your voice commands."
      }
    },
    "android": {
      "package": "com.yourcompany.aren",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ],
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3bda4fe-31d8-4441-8770-712135082083"
      }
    }
  }
}
